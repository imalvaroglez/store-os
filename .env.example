# Firebase configuration. Copy this file to `.env` and fill in your project's
# values from the Firebase console (Project settings → Your apps → SDK setup).
# These keys are PUBLIC by design — access is enforced by Firestore Security Rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" to route Auth + Firestore + Storage to the local emulator suite
# (npm run emulators). Tests/dev use this. In emulator mode, Storage always
# targets the explicit "store-os-demo.appspot.com" bucket regardless of this value.
VITE_FIREBASE_EMULATOR=true

# Optional: override the Storage emulator host (defaults to 127.0.0.1:9199).
# VITE_FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
